        DecorateFileNames,
        SetPoint BOTTOMRIGHT, "HeroButton_2", BOTTOMRIGHT, -0.002, 0.002,
        NormalTexture "ToolTipBackground",   
        NormalText "HeroLevelTextTemplate" "", 
    }

