IncludeFile "UI\FrameDef\UI\EscMenuTemplates.fdf",

String "HeroLevelTextTemplate" {
    Font "MasterFont", 0.008,
    FontColor 1.0 1.0 1.0,
}

Frame "SIMPLEFRAME" "HeroPanelElementFrame" {
    Width 0.112,
    Height 0.146,
    DecorateFileNames,

    Frame "POPUPMENU" "HeroPanelPlayerNameMenuFrame" {
        Width 0.106,
        Height 0.025,
        PopupButtonInset 0.01,
        SetPoint TOPLEFT, "HeroPanelElementFrame", TOPLEFT, 0.0, 0.0, // Position is set in CHeroPanelElement::OnFrameResize()

        ControlBackdrop "HeroPanelPlayerNameBackdrop",
        Frame "BACKDROP" "HeroPanelPlayerNameBackdrop" INHERITS "EscMenuButtonBackdropTemplate" {
			BackdropCornerSize  0.0125,
			BackdropBackgroundSize  0.128,
			BackdropBackgroundInsets 0.004 0.004 0.004 0.004,
            BackdropBackground  "ObserverStatisticsBackground",
            BackdropBlendAll,
        }

        ControlDisabledBackdrop "HeroPanelPlayerNameDisabledBackdrop",
        Frame "BACKDROP" "HeroPanelPlayerNameDisabledBackdrop" INHERITS "EscMenuButtonDisabledBackdropTemplate" {
			BackdropCornerSize  0.0125,
			BackdropBackgroundSize  0.128,
			BackdropBackgroundInsets 0.004 0.004 0.004 0.004,
            BackdropBackground  "ObserverStatisticsBackground",
            BackdropBlendAll,
        }

        PopupTitleFrame "HeroPanelPlayerNameMenuTitle",
        Frame "GLUETEXTBUTTON" "ReplayVisionMenuTitle" INHERITS WITHCHILDREN "EscMenuPopupMenuTitleTemplate" {
        }

        PopupArrowFrame "HeroPanelPlayerNameMenuArrow",
        Frame "BUTTON" "HeroPanelPlayerNameMenuArrow" INHERITS WITHCHILDREN "EscMenuPopupMenuArrowTemplate" { 
        }

        PopupMenuFrame "HeroPanelPlayerNameMenu",
        Frame "MENU" "HeroPanelPlayerNameMenu" INHERITS "EscMenuPopupMenuMenuTemplate" {
			DecorateFileNames,
			FrameFont "EscMenuTextFont",0.0066,"",
			MenuItemHeight 0.012,
			MenuBorder 0.01,
            Width 0.5,

			ControlBackdrop "HeroPanelPlayerNameMenuBackdropTemplate",
			Frame "BACKDROP" "HeroPanelPlayerNameMenuBackdropTemplate" INHERITS "EscMenuButtonBackdropTemplate" {
				DecorateFileNames,
				BackdropCornerSize  0.0125,
				BackdropBackgroundSize  0.128,
				BackdropBackgroundInsets 0.004 0.004 0.004 0.004,
				BackdropBackground "EscMenuEditBoxBackground",
			}
        }
    }

    Frame "SIMPLEFRAME" "HeroColourHolder" {
        DecorateFileNames,
        UseActiveContext,

        Layer "BACKGROUND" {
            Texture "HeroPlayerColourBackground" {
                Width 0.094,
                Height 0.014,
                SetPoint TOPLEFT, "HeroPanelPlayerNameMenuTitle", TOPLEFT, 0.009, 0.215, // Position is set in CHeroPanelElement::OnFrameResize()
                File "ObserverHeroPanelPlayerBacking",
            }
        }

        Layer "ARTWORK" {
            Texture "HeroPlayerColourIcon" {
                Width 0.007,
                Height 0.007,
                SetPoint TOPLEFT, "HeroPanelPlayerNameMenuTitle", TOPLEFT, 0.009, 0.215, // Position is set in CHeroPanelElement::OnFrameResize()
                File "ObserverPlayerColor",
            }
        }
    }

    /////////////////////////////////////////////////////////////////
    ///////////////////// Hero Buttons - 3 Heros ////////////////////
    /////////////////////////////////////////////////////////////////
    	
    Frame "SIMPLEBUTTON" "HeroButton_0" {
        UseActiveContext,
        DecorateFileNames,
        Width 0.026,
        Height 0.026,

        SetPoint TOPLEFT, "HeroPanelElementFrame", TOPLEFT, 0.012, -0.028,

        Texture "HeroColor_0" {
            Width 0.004,
            Height 0.036,
            SetPoint TOPRIGHT, "HeroButton_0", TOPRIGHT, -0.0275, 0.0,
            File "ObserverHeroPanelPlayerColor",
            TexCoord 0.0, 1.0, 0.0, 0.546875,
        }
    }

    Frame "SIMPLEBUTTON" "HeroButton_1" {
        UseActiveContext,
        DecorateFileNames,
        Width 0.026,
        Height 0.026,

        SetPoint TOPLEFT, "HeroPanelElementFrame", TOPLEFT, 0.012, -0.067,

        Texture "HeroColor_1" {
            Width 0.004,
            Height 0.036,
            SetPoint TOPRIGHT, "HeroButton_1", TOPRIGHT, -0.0275, 0.0,
            File "ObserverHeroPanelPlayerColor",
            TexCoord 0.0, 1.0, 0.0, 0.546875,
        }
    }

    Frame "SIMPLEBUTTON" "HeroButton_2" {
        UseActiveContext,
        DecorateFileNames,
        Width 0.026,
        Height 0.026,

        SetPoint TOPLEFT, "HeroPanelElementFrame", TOPLEFT, 0.012, -0.106,

        Texture "HeroColor_2" {
            Width 0.004,
            Height 0.036,
            SetPoint TOPRIGHT, "HeroButton_2", TOPRIGHT, -0.0275, 0.0,
            File "ObserverHeroPanelPlayerColor",
            TexCoord 0.0, 1.0, 0.0, 0.546875,
        }
    }

    /////////////////////////////////////////////////////////////////
    ///////////////// Hero Level Buttons - 1 Per Hero ///////////////
    /////////////////////////////////////////////////////////////////

    Frame "SIMPLEBUTTON" "HeroLevelButton_0" {
        UseActiveContext,
        Width 0.006,
        Height 0.01,
        DecorateFileNames,
        SetPoint BOTTOMRIGHT, "HeroButton_0", BOTTOMRIGHT, -0.002, 0.002,
        NormalTexture "ToolTipBackground",    
        NormalText "HeroLevelTextTemplate" "",
    }

    Frame "SIMPLEBUTTON" "HeroLevelButton_1" {
        UseActiveContext,
        Width 0.006,
        Height 0.01,
