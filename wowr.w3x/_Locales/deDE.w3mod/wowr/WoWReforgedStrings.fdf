    CC_CRUSADE                         "'-crusadeon/-crusadeoff': Enable/disable leaderboard.",
    CC_CENTAURS                        "'-centaurson/-centaursoff': Enable/disable leaderboard.",
    CC_PALADINS                        "'-paladinson/-paladinsoff': Enable/disable leaderboard.",
    CC_DRAENEI                         "'-draeneion/-draeneioff': Enable/disable leaderboard.",
    CC_DEMONS                          "'-demonson/-demonsoff': Enable/disable leaderboard.",
    CC_UNDEADS                         "'-undeadson/-undeadsoff': Enable/disable leaderboard.",
    CC_WHALES                          "'-whaleson/-whalessoff': Enable/disable leaderboard.",
    CC_OLD_GODS                        "'-oldgodson/off': Enables/disables leaderboard.",
    CC_INVASION                        "'-invasionon/off': Enables/disables leaderboard.",
    CC_ELEMENTAL                       "'-elementalon/off': Enables/disables leaderboard.",
    CC_WILD                            "'-wildon/off': Enables/disables leaderboard.",
    CC_AI_RESET                        "'-aireset': Resets the AI players and allows customizing them from the host.",
    CC_AI_RESPAWN                      "'-airespawn'/'-noairespawn': Enables/disables AI respawns.",
    CC_AI_EASY                         "'-aieasy X': Change AI difficulty to EASY for player X.",
    CC_AI_NORMAL                       "'-ainormal X': Change AI difficulty to NORMAL for player X.",
    CC_AI_HARD                         "'-aihard X': Change AI difficulty to HARD for player X.",
    CC_AI_INSANE                       "'-aiinsane X': Change AI difficulty to INSANE for player X.",
    CC_AI_NONE                         "'-ainone X': Change AI controller to none for player X.",
    CC_AI_NEUTRAL                      "'-aineutral X': Change AI controller to neutral for player X.",
    CC_AI_CREEP                        "'-aicreep X': Change AI controller to creep for player X.",
    CC_AI_COMPUTER                     "'-aicomputer X': Change AI controller to Computer for player X.",
    CC_AI_ON                           "'-aion/off X': Turn AI on/off for player X.",
    CC_AI_IGNORE_ALL                   "'-aiignoreall X': Disable AI unit control for player X.",
    CC_AI_IGNORE                       "'-aiignore': Disable AI unit control for all selected units.",
    CC_AI_USE                          "'-aiuse': Enable AI unit control for all selected units.",
    CC_AI_ATTACKS_ON                   "'-aiattackson/off X': Turn AI attacks on/off for player X.",
    CC_AI_ATTACKS_PLAYERS_ON           "'-aiattacksplayerson/off X': Turn AI player attacks on/off for player X.",
    CC_AI_SHIPS_ON                     "'-aishipsson/off X': Turn AI ships on/off for player X.",
    CC_AI_GOLD                         "'-aigold/wood X': Ask AI player X for gold/wood.",
    CC_AI_EXPANSIONS                   "'-aiexpansions X Y': Sets Y expansions for player X.",
    CC_AI_SHREDDERS                    "'-aishredders X Y': Sets Y shredders for player X.",
    CC_AI_ZEPPELINS                    "'-aizeppelins X Y': Sets Y zeppelins for player X.",
    CC_AI_HERO                         "'-aihero X Y Z': Replaces hero Y with Z for player X.",
    CC_AI_LOAD_MINES                   "'-ailoadmines X': Loads mines for player X.",
    CC_AI_REVIVE                       "'-airevive X': Revives heroes for player X.",
    CC_AI_PROFESSION                   "'-aiprofession X Y': Changes profession of allied player X to Y.",
    CC_AI_INFO                         "'-aiinfo X': Shows information about player X.",
    CC_AI_TARGET_ON                    "'-aitargeton/off X': Enables/disables AI attacking target for player X.",
    CC_AI_TARGET                       "'-aitarget X': Sets the AI target for player X to your hero 1 location.",
    CC_AI_TRACE_ON                     "'-aitraceon/off X': Enables/disables AI trace for player X.",
    CC_SAVE                            "'-save': Saves your hero and prints the savecode.",
    CC_SAVE_C                          "'-savec'/'-s': Saves your hero without info.",
    CC_SAVE_AUTO_ON                    "'-saveautoon/off': Enables/disables auto saving of your hero.",
    CC_SAVE_GUI                        "'-savegui': Shows the GUI for savecodes.",
    CC_A_SAVE                          "'-asave': Saves all savecodes in the auto load file.",
    CC_A_LOAD                          "'-aload': Loads all save codes from the auto load file.",
    CC_A_RESET                         "'-areset': Allows saving and loading automatic save codes.",
    CC_LOAD                            "'-load X'/'-l X': Loads your hero from savecode X.",
    CC_LOAD_X                          "'-loadi/u/b/r X': Loads items, units, buildings or researches from savecode X.",
    CC_LOAD_RES                        "'-loadres X': Loads your resources from savecode X.",
    CC_SAVE_CHECK                      "'-savecheck X': Checks savecode X.",
    CC_GENERATED                       "'-generated': Lists all generated savecodes from the current game.",
    CC_CLEAR_GENERATED                 "'-cleargenerated': Clears all generated savecodes from the current game.",
    CC_ENCHANTER                       "'-e/-enchanter': Lists enchanting bonuses and items.",
    CC_INSCRIPTOR                      "'-n/-inscriptor': Lists inscription bonuses and spells.",
    CC_TROPHIES                        "'-t/-trophies': Lists hunting trophies.",
    CC_DICE                            "'-dice X': Throws a dice with X numbers.",
    CC_HOST                            "'-host': Shows the host player of the game.",
    CC_ACCOUNTS                        "'-a/-accounts': Lists all known account names.",
    CC_VIPS                            "'-vips': Lists all VIPs.",
    CC_UNLOCKED                        "'-u/-unlocked': Lists everything unlocked for your account.",
    CC_BANS                            "'-b/-bans': Lists all banned account names.",
    CC_GOLD                            "'-gold X Y': Gives Y of your gold to player X.",
    CC_LUMBER                          "'-lumber X Y': Gives Y of your lumber to player X.",
    CC_TOMES                           "'-tomes'/'-notomes': Enables/disables tomes.",
    CC_CINEMATICS                      "'-cinematics'/'-nocinematics': Enables/disables cinematics.",
    CC_RESOURCES                       "'-r/-res/-resources X': Shows the resources of player X or your resources.",
    CC_RES_GUI                         "'-resguion/-resgui'/'-resguioff': Shows/hides the resource GUI.",
    CC_GIVE                            "'-give X Y Z': Gives the amount X of resource Y to player Z.",
    CC_ASK                             "'-ask X Y Z': Asks for the amount X of resource Y from allied Computer player Z.",
    CC_SELL                            "'-sell X Y': Sells the amount X of resource Y for gold.",
    CC_SELL_ALL                        "'-sellall/-sa': Sells all resources except gold and lumber for gold.",
    CC_SELL_WOOD                       "'-sellwood/-sw': Sells all lumber for gold.",
    CC_BUY                             "'-buy X Y': Buys the amount X of resource Y for gold.",
    CC_RESOURCES_INFO                  "'-resinfo/-resourcesinfo': Shows the resource information about the first selected unit.",
    CC_SAVE_CODES                      "'-savecodes/-nosavecodes': Enables/disables savecodes for all players.",
    CC_ACHIEVEMENTS                    "'-achievements': Lists all available achievements with your score.",
    CC_STR                             "'-str X': Skills X strength. Skills max strength if empty.",
    CC_AGI                             "'-agi X': Skills X agility. Skills max agility if empty.",
    CC_INT                             "'-int X': Skills X intelligence. Skills max intelligence if empty.",
    CC_RENAME                          "'-rename X': Renames selected heroes into X.",
    CC_SAY                             "'-say X': The selected unit says X.",
    CC_SHOUT                           "'-shout X': The selected unit shouts X.",
    CC_BUILDER                         "'-builder'/'-nobuilder': Creates/removes a builder for player 1 red.",
    CC_RENAME                          "'-rename X': Renames selected heroes into X.",
    CC_SCALE                           "'-scale X': Scales selected units to X.",
    CC_TEAM_COLOR                      "'-teamcolor X': Changes the team color of selected units to X.",
    CC_PLAYER_COLOR                    "'-playercolor X Y': Changes the color of player X into Y.",
    CC_PLAYER_NAME                     "'-playername X Y': Changes the name of player X into Y.",
    CC_MOUNT_NAME                      "'-mountname1/2/3 X': Changes the name of the mount to X.",
    CC_CIN_DALARAN                     "'-cindalaran': Plays the cinematic Dalaran.",
    CC_AMBIENT_SOUND                   "'-ambientsound': Resets ambient sound to Sunken Ruins.",
    CC_AMBIENT_SOUND_A                 "'-ambientsoundashenvale': Changes ambient sound to Ashenvale.",
    CC_AMBIENT_SOUND_L                 "'-ambientsoundlordaeronsummer': Changes ambient sound to Lordaeron Summer.",
    CC_NO_AMBIENT_SOUND                "'-noambientsound': Disables ambient sound.",
    CC_SKY                             "'-sky': Resets sky to Lordaeron Summer.",
    CC_SKY_A                           "'-skyashenvale': Changes sky to Ashenvale.",
    CC_SKY_B                           "'-skybarrens': Changes sky to Barrens.",
    CC_SKY_BLIZZARD                    "'-skyblizzard': Changes sky to Blizzard.",
    CC_SKY_X                           "'-skydalaran': Changes sky to Dalaran.",
    CC_SKY_J                           "'-skydalaranruins': Changes sky to Dalaran Ruins.",
    CC_SKY_C                           "'-skyfelwood': Changes sky to Felwood.",
    CC_SKY_FOGGED                      "'-skyfogged': Changes sky to Fogged.",
    CC_SKY_GENERIC                     "'-skygeneric': Changes sky to Generic.",
    CC_SKY_MOON                        "'-skymoon': Changes sky to Moon.",
    CC_FOOD                            "'-food50/100/200/300/600': Changes the maximum food.",
    CC_LIMITS                          "'-limits'/'-nolimits': Enables/disables housing and tower limits.",
    CC_SEASONS                         "'-seasons'/'-noseasons': Enables/disables seasons.",
    CC_WINTER                          "'-winter': Changes season to winter.",
    CC_SPRING                          "'-spring': Changes season to spring.",
    CC_SUMMER                          "'-summer': Changes season to summer.",
    CC_FALL                            "'-fall': Changes season to fall.",
    CC_WEATHER                         "'-weather'/'-noweather': Starts/stops weather immediately.",
    CC_MORNING                         "'-morning': Changes time of day to 6.",
    CC_NOON                            "'-noon': Changes time of day to 12.",
    CC_EVENING                         "'-evening': Changes time of day to 18.",
    CC_MIDNIGHT                        "'-midnight': Changes time of day to 24.",
    CC_DNC                             "'-dnc'/'-nodnc': Enables/disables day and night cycle.",
    CC_WATER                           "'-water'/'-nowater': Enables/disables visibility of water.",
    CC_WATER_RED                       "'-waterred': Changes the color of water to red.",
    CC_FOG                             "'-fog'/'-nofog': Enables/disables visibility of fog.",
    CC_REVEAL                          "'-reveal'/'-noreveal': Enables/disables complete map visibility.",
    CC_CHEATS                          "'-cheats'/'-nocheats': Enables/disables cheat chat commands.",
    CC_RESET_REVOLUTION                "'-resetevolution X': Resets level of research Evolution back to X.",
    // Info Quests
    IQ_MAP_TITLE                       "Karte",
    IQ_MAP_DESCRIPTION                 "Willkommen in World of Warcraft Reforged. Bei dieser Karte handelt es sich um ein Rollenspiel mit offener Welt. Das bedeutet , Sie können tun und lassen, was immer Sie wollen. Erfüllen Sie einige der optionalen Quests, jagen Sie andere Spieler oder schmieden Sie Allianzen. Baradé wünscht Ihnen viel Spaß beim Spielen. Ich bedanke mich bei EvilPitlord und DeMoNiKuS für die Erstellung der ursprünglichen Karte 'World of Warcraft Reborn'.",
    IQ_MAP_0                           "Ersteller: Baradé",
    IQ_MAP_1                           "Gebt bitte Feedback.",
    IQ_MAP_2                           "Website: https://tdauth.github.io/wowr-website",
    IQ_MAP_3                           "Discord: https://discord.gg/eM34z36",
    IQ_MAP_4                           "Entwicklung: https://github.com/tdauth/wowr",
    IQ_SUPPORT_TITLE                   "Unterstützen",
    IQ_SUPPORT_DESCRIPTION             "Support the creator of the map. VIPs are allowed to enter the VIP room and the secret chamber from the beginning. It provides them some bonuses in the game which should not be too unfair but still give them a bit of advantage or at least a visible status in the game. VIPs are usually players who helped to improve the map over time.",
    IQ_SUPPORT_1                       "Unterstützt das Projekt, um die Qualität zu verbessern.",
    IQ_SUPPORT_2                       "Unterstützt das Projekt mit einem Abonnement, um VIP zu werden.",
    IQ_SUPPORT_4                       "Schaltet exklusive Inhalte in der Karte frei.",
    IQ_SUPPORT_5                       "VIP-Status auf Discord.",
    IQ_CHAT_COMMANDS_TITLE             "Chat-Befehle",
    IQ_CHAT_COMMANDS_DESCRIPTION       "Enter the chat commands without the single quotes. The leaderboards will appear during certain quests. Note: Even when the quest has been activated, and you turn off the leaderboard, the counts will continue until the quest requirement is accomplished. Also, it turns off/on the leaderboard display only for the player who writes the chat message.",
    IQ_U_CHAT_COMMANDS_TITLE           "Universal Chat Commands",
    IQ_U_CHAT_COMMANDS_DESCRIPTION     "Enter the chat commands without the double quotes. These chat commands are available by Warcraft III: Reforged and in Battle.net.",
    IQ_U_CHAT_COMMANDS_0               "'/help X': Shows usage help for topic X (whisper etc.).",
    IQ_U_CHAT_COMMANDS_1               "'/fps': Shows FPS.",
    IQ_U_CHAT_COMMANDS_2               "'/ping': Shows ping.",
    IQ_U_CHAT_COMMANDS_3               "'/whois X': Shows information about Battle.net user X.",
    IQ_U_CHAT_COMMANDS_4               "'/whoami': Shows information about your Battle.net user.",
    IQ_U_CHAT_COMMANDS_5               "'/w X': Sends a private message to Battle.net user X.",
    IQ_U_CHAT_COMMANDS_6               "'/ignore X': Ignores all future messages from Battle.net user X.",
    IQ_U_CHAT_COMMANDS_7               "'/unignore X': Unignores all future messages from Battle.net user X.",
    IQ_U_CHAT_COMMANDS_8               "'/users': Shows number of users currently on Battle.net.",
    IQ_U_CHAT_COMMANDS_9               "'/time': Shows passed game time.",
    IQ_HERO_JOURNEY_TITLE              "Heldenreise",
    IQ_HERO_JOURNEY_DESCRIPTION        "Ihre Heldenstufen werden neue Features in der Karte freischalten.",
    IQ_KNOWN_ISSUES_TITLE              "Bekannte Probleme",
    IQ_KNOWN_ISSUES_DESCRIPTION        "Unfortunately, this map has some known unfixed issues. If you think you know the cause of an issue or the solution to fix it, please report it on Discord.",
    IQ_KNOWN_ISSUES_0                  "Lange Ladezeiten führen für einige Spieler zu Fehlern.",
    IQ_KNOWN_ISSUES_1                  "Enchanting does not work for all item abilities due to Warcraft bugs.",
    IQ_KNOWN_ISSUES_2                  "Goblin Town Hall has a weird light bug pointing to the hero glow.",
    IQ_KNOWN_ISSUES_3                  "Goblin Tower leads to terrain becoming black sometimes.",
    IQ_KNOWN_ISSUES_4                  "Line of Sight Blockers do not work for flying units (occlusion height).",
    IQ_KNOWN_ISSUES_5                  "Researches increasing unit maximum life can lead to negative maximum life and instant unit deaths.",
    IQ_KNOWN_ISSUES_6                  "Release 2.0 of Warcraft III broke older version before 3.31 with a new frame hierarchy.",
    IQ_KNOWN_ISSUES_7                  "AI might crash in start locations which have too little ground area space.",
    IQ_KNOWN_ISSUES_8                  "Loading save games might crash because of string literals longer than 1023 characters.",
    IQ_KNOWN_ISSUES_9                  "Tooltips von passiven Fähigkeiten werden nicht aktualisiert.",
    IQ_FACTIONS_TITLE                  "Fraktionen",
    IQ_FACTIONS_DESCRIPTION            "Factions consist of multiple races which allied for a common goal. The two game lobby teams represent the two major factions Alliance and Horde. Players from the same faction are allied by default. The faction The Burning Legion fights against all players. The faction Rescuable allows rescuing respawning units.",
    IQ_FACTIONS_0                      "Races belong to one faction or are neutral.",
    IQ_GAME_MODES_TITLE                "Spielmodi",
    IQ_GAME_MODES_DESCRIPTION          "You can choose one of two game modes after the hero selection. As a warlord you play partly in the strategy mode and can build a base. This has the advantage that you have mostly a bigger army than other players. On the other hand, as a freelancer your hero starts with +15 points on all attributes and your hero gets 30% more experience from killing hostile units. Freelancers can see neutral buildings from start.",
    IQ_GAME_MODES_WARLORD              "Kriegsherr: Teilweise Strategiemodus.",
    IQ_GAME_MODES_FREELANCER           "Freiberufler: Reiner RPG-Modus, startet mit +15 Attributen und +30 % XP-Rate.",
    IQ_PLAYERS_TITLE                   "Spieler",
    IQ_PLAYERS_DESCRIPTION             "Players own heroes, units, buildings and resources. The number of players is determined in the game lobby. Computer players play with Warcraft's AI. Empty slots will not be playing. Users can leave at any time during a game. Users can also be kicked from games by votes.One single player is the host.The ownership of units can be transfered to other players using spells like Charm or chat commands. Players can use their save codes to to save/load data during a game. There are several fixed Computer players which cannot be changed in the game lobby. Alliances between players are preset by their game lobby team. Alliances can be changed during the game using chat commands.",
    IQ_PLAYERS_RESCUABLE               "Fixed Computer player Rescuable allows rescuing units.",
    IQ_PLAYERS_BOSSES                  "Player Bosses owns all bosses and is allied with all creeps.",
    IQ_PLAYERS_NEUTRAL_HOSTILE         "Player Neutral Hostile owns all creeps and is allied with all bosses.",
    IQ_PLAYERS_NEUTRAL_PASSIVE         "Player Neutral Passive owns all NPCs and neutral buildings.",
    IQ_CLASSES_DESCRIPTION             "Hero classes determine which spells can be learned by a hero. They give the hero certain traits which are useful when combined with other hero classes.",
    IQ_HEROES_DESCRIPTION              "You have to pick a hero in the beginning of the game which can be repicked. You are allowed to pick two additional heroes at some point when you reached a higher level with your first hero.",
    IQ_HEROES_0                        "Die maximale Stufe ist 75.",
    IQ_HEROES_1                        "Additional, bonus and boss heroes require a higher hero level of your first hero.",
    IQ_HEROES_2                        "Hero 2 and 3 have no backpack and no equipment bags.",
    IQ_PROFESSIONS_TITLE               "Berufe",
    IQ_PROFESSIONS_DESCRIPTION         "After choosing your race or game mode, you have to select a profession. The profession allows you to craft items. These items might help your hero or units to become stronger or to restore their stats or to fortify your base. Crafting items costs mana.",
    IQ_PROFESSIONS_0                   "Craft items.",
    IQ_PROFESSIONS_1                   "Additional professions require a higher hero level of your first hero.",
    IQ_PROFESSIONS_2                   "Higher hero levels reduce the crafting cooldowns and increases crafted charges.",
    IQ_RACES_TITLE                     "Races",
    IQ_RACES_DESCRIPTION               "This selection is restricted to warlords. They receive a scepter and tiny town hall of their race which allows them to summon two workers and therefore to build their first base.",
    IQ_RACES_0                         "Nur für Kriegsherren.",
    IQ_RACES_1                         "Additional races require a higher hero level of your first hero.",
    IQ_START_LOCATIONS_TITLE           "Startorte",
    IQ_START_LOCATIONS_DESCRIPTION     "The start locations allow you to start the game at some specified area on the map. Some start locations may be occupied by other players including Warlord AI.",
    IQ_VICTORY_TITLE                   "Sieg",
    IQ_VICTORY_DESCRIPTION             "Every player can win the game by killing the boss Archimonde if the victory conditions are enabled. The game ends after this. All players who are not allied with the killing player will lose the game.",
    IQ_AI_TITLE                        "Computer-KI (Respawn %1%)",
    IQ_AI_DESCRIPTION                  "Computer players are warlords by default. They start with a main building, five workers and their hero. The AI will collect gold and lumber and build additional gold mines. It should attack creeps and hostile players from time to time. If you are allied to a computer player it is recommended to defend him and to give him resources if you are a warlord yourself. Allied computer players might turn out to be rather useful when attacking another player. When the base of a computer player is destroyed, the hero will get a tiny main building to rebuild a base. Their race is defined in the beginning by the host player.",
    IQ_AI_0                            "Change alliances to get control.",
    IQ_CHEATS_TITLE                    "Cheats",
    IQ_CHEATS_DESCRIPTION              "Cheats are useful for testing the map. They are enabled automatically for player WorldEdit in singleplayer.",
    IQ_CHEATS_UNFREEZE                 "'-unfreeze': Unfreezes everything.",
    IQ_CHEATS_NO_CREEPS                "'-nocreeps': Removes all creep/neutral hostile units.",
    IQ_CHEATS_NO_BOSSES                "'-nobosses': Removes all boss units.",
    IQ_CHEATS_NO_PASSIVE               "'-nopassive': Removes all neutral passive units.",
    IQ_CHEATS_CREEPS                   "'-creeps': Lists creeps and critters placed on the map which are not registered for savecodes.",
    IQ_CHEATS_CIN_INTRO                "'-cinintro': Shows the intro cinematic.",
    IQ_CHEATS_CIN_OUTRO                "'-cinoutro': Shows the outro cinematic.",
    IQ_CHEATS_CIN_LICH_KING            "'-cinlichking': Shows the Lich King cinematic.",
    IQ_CHEATS_CIN_OLD_GODS             "'-cinoldgods': Shows the Old Gods cinematic.",
    IQ_CHEATS_CIN_INVASION             "'-cininvasion': Shows the Invasion cinematic.",
    IQ_CREEPS_TITLE                    "Unholde",
    IQ_CREEPS_DESCRIPTION              "You can kill creeps to increase the level of your hero. There is different creeps everywhere in the world. When you kill a group of computer-controlled creeps, it will be respawned after %1%, so the number of opponents in the game is not finite. Some groups leave items after their extermination which can be picked up by your hero. The creeps won't respawn if there is a building in the area. When the building is destroyed, the creeps will respawn again.",
    IQ_BOSSES_TITLE                    "Bosse",
    IQ_BOSSES_DESCRIPTION              "Legends and rumors speak of many legendary Artifacts hidden across the World. The bad news is, you can´t get them for free, but in order to retrieve them, must defeat each boss guarding them. Since the bosses are very powerful, it is advised not to venture alone into their lairs, or at least not well prepared. If a hero carrying a unique artifact dies without an Ankh or the Reincarnation skill, the artifacts will be removed from the hero. They can then again be retrieved from the location where they were originally found. Dead bosses will respawn automatically after %1%.",
    IQ_BOSSES_0                        "Dead bossses will respawn automatically after %1%.",
    IQ_BOSSES_1                        "Killing bosses allows to get legendary items.",
    IQ_BOSSES_2                        "Legendary items will be reset to their initial drop location on hero deaths.",
    IQ_QUESTS_TITLE                    "Quests",
    IQ_QUESTS_DESCRIPTION              "Solve optional quests to get items as rewards. NPCS with an exclamation mark over their head offer quests. Any discovered quest can be completed only once during the game.",
    IQ_QUESTS_0                        "Discover and complete quests by approaching marked NPCs with your hero.",
    IQ_QUESTS_1                        "Quest items will be reset to their initial drop location on hero deaths.",
    IQ_QUESTS_2                        "Completing quests creates unique items as reward.",
    IQ_SAVE_CODES_TITLE                "Speicher-Codes (%1%)",
    IQ_SAVE_CODES_DESCRIPTION          "You can save your current game progress and load it in any other later game. However, it is restricted to your current game mode since the game mode determines how fast your heroes gain experience. Check out the folder '%userprofile%\Documents\Warcraft III\CustomMapData\wowr' and sort the text files in there by modification time. Look for the text files with your Battle.net account name. They contain your save codes. You can copy and paste the -load chat commands into the Warcraft chat and load them in any other game. You cannot load save codes from your current game in the same game.",
    IQ_PORTALS_TITLE                   "Portale",
    IQ_PORTALS_DESCRIPTION             "Portals can also be built by Citizens to connect your different locations on the map directly with each other. This makes moving units around much faster. A research allows your built portals to teleport your units to any discovered location on the map except it is protected by an Antimagic Ward.",
    IQ_PORTALS_0                       "Können von Bürgern errichtet werden.",
    IQ_PORTALS_1                       "Verbinden Orte direkt miteinander.",
    IQ_PORTALS_2                       "Teleport units to any discovered area if upgraded.",
    IQ_PORTALS_3                       "Protect locations against enemy portals with Antimagic Wards.",
    IQ_TOMES_TITLE                     "Folianten (%1%)",
    IQ_TOMES_DESCRIPTION               "Tomes are items which increase hero stats permanently. Hence, they are disabled by default to keep the game balanced. However, they can be enabled by a vote. This allows buying and crafting tomes as well as loading them via save codes.",
    IQ_TOMES_0                         "Items which increase hero stats permanently.",
    IQ_TOMES_1                         "Can only be loaded with save codes if enabled.",
    IQ_TOMES_2                         "Available in the Library at Theramore.",
    IQ_TOMES_3                         "Profession Scribe allows crafting tomes.",
    IQ_CINEMATICS_TITLE                "Videos (%1%)",
    IQ_CINEMATICS_DESCRIPTION          "Cinematics are optional ingame video sequences which help immersion and story telling.",
    IQ_CINEMATICS_0                    "Shown to all players at the same time.",
    IQ_CINEMATICS_1                    "Can be skipped with the Escape key.",
    IQ_CREDITS_TITLE                   "Mitwirkende",
    IQ_CREDITS_DESCRIPTION             "Alle Leute, die an dieser Karte mitgewirkt haben.",
    // Quests
    // MainQuest1
    Q_ARCHIMONDE_DESCRIPTION           "Archimonde has returned to this world to conquer it with the help of his Burning Legion. Travel to Outland, find and defeat him to protect Azeroth.",
    Q_ARCHIMONDE_0                     "Besiegt Archimonde.",
    // HumanQuest1
    Q_DRAGON_SLAYER_TITLE              "Drachentöter",
    Q_DRAGON_SLAYER_DESCRIPTION        "Lately there has been some harassment by an evil Red Dragon that recently appeared in the region. The creature has caused serious damage to the defenses of Nethergarde Citadel and now the wizards there have had enough! There is a substantional reward to the hero who kills the dragon and returns its heart to the Archmage of Nethergarde.",
    Q_DRAGON_SLAYER_0                  "Kill the Red Dragon.",
    Q_DRAGON_SLAYER_1                  "Bring the Red Dragon's heart to the Archmage of Nethergarde.",
    // HumanQuest2
    Q_GOLEM_FACTORY_TITLE              "Golem-Fabrik",
    Q_GOLEM_FACTORY_DESCRIPTION        "The Engineers of Ironforge have discovered some very interesting blueprints in the city´s library: apparently there seems to be a long abandoned and forgotten Golem Factory somewhere under the city. This subject has drawn the Dwarf King´s attention since Golems would be an invaluable weapon against the increasing Undead threat. King Magni Bronzebeard requires brave adventurers to travel into the unexplored corridors deep under the city, and if the rumor is true, bring a Battle Golem to him as a proof of the factory´s existence!",
    Q_GOLEM_FACTORY_0                  "Purchase a Battle Golem from the forgotten Golem Factory.",
    Q_GOLEM_FACTORY_1                  "Bring the Battle Golem to King Magni Bronzebeard.",
    // HumanQuest3
    Q_SEARCH_FOR_MURADIN_TITLE         "Die Suche nach Muradin",
    Q_SEARCH_FOR_MURADIN_DESCRIPTION   "Although it may be a suicide mission, the High King of the Dwarves requests that you travel to Icecrown and find out what happened to Muradin Bronzebeard, the High King´s brother. Find the Dwarf and, should he still live, escort safely him back to Ironforge!",
    Q_SEARCH_FOR_MURADIN_0             "Find Muradin.",
    Q_SEARCH_FOR_MURADIN_1             "Return Muradin to Magni Bronzebeard.",
    // HumanQuest4
    Q_CRUSADE_TITLE                    "Kreuzzug",
    Q_CRUSADE_DESCRIPTION              "The time has come to take countermeasures against the increasing threat caused by the Scourge! To prevent another cataclysm like in Lordaeron, King Anduin Wrynn and the Order of the Silver Hand have called out a Crusade against the Undead. Heros throughout the land are called for to hunt down and destroy 5 Undead heros to avenge the death of legendary Sir Uther Lightbringer and the downfall of the Order of the Silver Hand in Lordaeron!",
    Q_CRUSADE_0                        "Tötet 5 untote Helden.",
    Q_CRUSADE_1                        "Bring the trophy to King Anduin Wrynn.",
    // VillageQuest1
    Q_BANDIT_LORD_TITLE                "Banditen-Lord",
    Q_BANDIT_LORD_DESCRIPTION          "The cunning Bandit Lord, Menag, has been terrorizing the lands around Strahnbrad for months. He and his lackeys just made off with a ledger full of vital information regarding the estate of the local farmer, Gerard.",
    Q_BANDIT_LORD_0                    "Tötet den Banditen-Lord.",
    Q_BANDIT_LORD_1                    "Return Ledger to Gerard.",
    // VillageQuest2
    Q_FIEF_TITLE                       "Lehen",
    Q_FIEF_DESCRIPTION                 "The village needs protection from the kingdom of Stormwind. Visit New Stormwind and get some equipment to arm some villagers. Bring the equipment to Gerard to receive your reward.",
    Q_FIEF_0                           "Besorgt Ausrüstung in Neu-Sturmwind.",
    Q_FIEF_1                           "Bringt die Ausrüsrtung zu Gerard.",
    // VillageQuest3
    Q_HARVEST_TITLE                    "Ernte",
    Q_HARVEST_DESCRIPTION              "It is harvest time in the village. Harvest wheat, bring the it to the wind mill to get flour, deliver the flour to the tavern to get bread, sell the bread to Theramore and return the gold to Gerard to receive your reward.",
    Q_HARVEST_0                        "Erntet Weizen.",
    Q_HARVEST_1                        "Bring the wheat to the wind mill.",
    Q_HARVEST_2                        "Bring the flour to the tavern.",
    Q_HARVEST_3                        "Sell the bread to Theramore.",
    Q_HARVEST_4                        "Return the gold to Gerard.",
    // VillageQuest4
    Q_THE_PLAGUE_TITLE                 "Die Seuche",
    Q_THE_PLAGUE_DESCRIPTION           "The grain has been plagued by the Undead Scourge. Villagers are converted into Undead. You must get some spells from Dalaran to stop the Plague and fight the Undead attacking the village. Get your reward from Gerard after completing the tasks.",
    Q_THE_PLAGUE_0                     "Get some spells from Dalaran.",
    Q_THE_PLAGUE_1                     "Fight the Undead attacking the village.",
    Q_THE_PLAGUE_2                     "Bring the Zombie Heads to Gerard to receive your reward.",
    // DalaranQuest1
    Q_RECONSTRUCTION_TITLE             "Reconstruction",
    Q_RECONSTRUCTION_DESCRIPTION       "Archimonde has fully destroyed Dalaran during the third war. Khadgar and the Kirin Tor have reconstructed the city flying in the sky. To fully reconstruct the city, they need more material from human allies. Travel to Jaina and get some material from Theramore. Return the material to Khadgar to get your reward.",
    Q_RECONSTRUCTION_0                 "Bring the letter to Jaina on Theramore.",
    Q_RECONSTRUCTION_1                 "Return the material to Khadgar in Dalaran.",
    // DalaranQuest2
    Q_FIRE_ELEMENTAL_TITLE             "Fire Elemental",
    Q_FIRE_ELEMENTAL_DESCRIPTION       "Khadgar needs an Enraged Fire Elemental for experiments giving the Kirin Tor the ability to summon Fire Elementals. Get an Enraged Fire Elemental in Firelands and return it to Khadgar to receive your reward.",
    Q_FIRE_ELEMENTAL_0                 "Hire an Enraged Fire Elemental.",
    Q_FIRE_ELEMENTAL_1                 "Bring the Enraged Fire Elemental to Khadgar in Dalaran.",
    // DalaranQuest3
    Q_ARCANE_MAGIC_TITLE               "Arcane Magic",
    Q_ARCANE_MAGIC_DESCRIPTION         "Khadgar and the Kirin Tor need to create a magic shield around the city of Dalaran to protect it. Construct the power generator to enable the shield. Return the letter of the engineers to Khadgar to receive your reward.",
